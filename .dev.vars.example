# Environment Variables for Local Development
# DO NOT commit this file to version control

# Application URL (production domain)
APP_URL=https://fortetrain.com

# OpenAI API Key (for AI workout generation and Vision module)
OPENAI_API_KEY=your-openai-api-key-here

# YouTube Data API v3 Key (for equipment video search)
YOUTUBE_API_KEY=your-youtube-api-key-here

# JWT Secret (for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Mercado Pago API Keys (for payments - Brazilian market)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-access-token-here
MERCADOPAGO_PUBLIC_KEY=APP_USR-your-public-key-here
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret-here

# WhatsApp API (optional - for notifications)
WHATSAPP_API_TOKEN=your-whatsapp-business-api-token
